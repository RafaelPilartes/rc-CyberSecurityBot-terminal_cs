<Window x:Class="CyberSecurityBot.Wpf.Views.NameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome" Height="220" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="CYBER BOT"
                   Foreground="{StaticResource PrimaryBrush}"
                   FontFamily="{StaticResource MonoFont}"
                   FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock Grid.Row="1" Text="What should I call you?"
                   Foreground="{StaticResource PrimaryBrush}"
                   FontFamily="{StaticResource MonoFont}"
                   FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,8"/>
        <TextBox x:Name="NameInput" Grid.Row="2"
                 Style="{StaticResource ChatTextBox}"
                 MaxLength="30"
                 KeyDown="NameInput_KeyDown"/>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Skip" Click="Skip_Click" Style="{StaticResource SendButton}" Margin="0,0,8,0" Background="#FF333333" Foreground="{StaticResource PrimaryBrush}"/>
            <Button Content="OK" Click="Ok_Click" Style="{StaticResource SendButton}"/>
        </StackPanel>
    </Grid>
</Window>
