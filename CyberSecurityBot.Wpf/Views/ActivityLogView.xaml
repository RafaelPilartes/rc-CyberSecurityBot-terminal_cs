<UserControl x:Class="CyberSecurityBot.Wpf.Views.ActivityLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Recent activity (last 5–10 actions)"
                   Foreground="{StaticResource PrimaryBrush}" FontFamily="{StaticResource MonoFont}"
                   FontSize="14" Margin="0,0,0,12"/>

        <!-- Log entries (structure only) -->
        <ListView Grid.Row="1" ItemsSource="{Binding Entries}" Background="#FF111111"
                  BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1"
                  Foreground="{StaticResource PrimaryBrush}" FontFamily="{StaticResource MonoFont}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Time" Width="120" DisplayMemberBinding="{Binding Timestamp, StringFormat=HH:mm:ss}"/>
                    <GridViewColumn Header="Action" Width="520" DisplayMemberBinding="{Binding Description}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
