<Window x:Class="CyberSecurityBot.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CyberSecurityBot.Wpf.Views"
        Title="Cyber Bot — Cybersecurity Awareness Assistant"
        Height="720" Width="900" MinHeight="500" MinWidth="600"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF050505" Padding="12" CornerRadius="8">
            <StackPanel>
                <TextBlock x:Name="AsciiArtBlock"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="10"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <TextBlock Text="CYBER BOT — Cybersecurity Awareness Assistant"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="14"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="0,12,0,0" Background="Transparent" BorderBrush="{StaticResource PrimaryBrush}">
            <TabItem Header="Chat" Style="{StaticResource TerminalTabItem}">
                <views:ChatView DataContext="{Binding Chat}" Margin="8"/>
            </TabItem>
            <TabItem Header="Tasks" Style="{StaticResource TerminalTabItem}">
                <views:TasksView DataContext="{Binding Tasks}" Margin="8"/>
            </TabItem>
            <TabItem Header="Quiz" Style="{StaticResource TerminalTabItem}">
                <views:QuizView DataContext="{Binding Quiz}" Margin="8"/>
            </TabItem>
            <TabItem Header="Activity Log" Style="{StaticResource TerminalTabItem}">
                <views:ActivityLogView DataContext="{Binding ActivityLog}" Margin="8"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
