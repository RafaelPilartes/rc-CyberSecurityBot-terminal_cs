<UserControl x:Class="CyberSecurityBot.Wpf.Views.MessageBubble"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CyberSecurityBot.Wpf.Converters">
    <UserControl.Resources>
        <conv:SenderToAlignmentConverter x:Key="AlignConv"/>
        <conv:SenderToBrushConverter x:Key="BgConv"/>
        <conv:SenderToForegroundConverter x:Key="FgConv"/>
        <conv:SenderToPrefixConverter x:Key="PrefixConv"/>
    </UserControl.Resources>
    <Border CornerRadius="10"
            Padding="12,8"
            Margin="8,4"
            MaxWidth="520"
            HorizontalAlignment="{Binding Sender, Converter={StaticResource AlignConv}}"
            Background="{Binding Sender, Converter={StaticResource BgConv}}">
        <StackPanel>
            <TextBlock TextWrapping="Wrap"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="14"
                       Foreground="{Binding Sender, Converter={StaticResource FgConv}}">
                <Run Text="{Binding Sender, Converter={StaticResource PrefixConv}, Mode=OneWay}"/>
                <Run Text="{Binding Text, Mode=OneWay}"/>
            </TextBlock>
            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                       Foreground="#FF666666"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="10"
                       Margin="0,4,0,0"
                       HorizontalAlignment="Right"/>
        </StackPanel>
    </Border>
</UserControl>
